DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Use PostgreSQL in development/production:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/replyo

# Frontend origins allowed to call the API:
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
FRONTEND_URL=http://127.0.0.1:3000

# Meta / Instagram OAuth (required for production Instagram connect):
# META_APP_ID=
# META_APP_SECRET=
# META_REDIRECT_URI=http://127.0.0.1:8000/api/integrations/instagram/callback/
# META_WEBHOOK_VERIFY_TOKEN=replyo-dev-webhook-token
